<% content_for :page_heading do %>
  <h2>
    <%= t('.manage_articles') %>
    <%= link_to(t('.new_article'), { controller: 'articles', action: 'new' }, { id: 'dialog-link', class: 'btn btn-info float-right' }) %>
  </h2>
<% end %>

<%= form_tag({ action: 'index' }, { method: :get, name: 'article', remote: true, class: 'spinnable', "data-update-success": 'articleList' }) do %>

  <% if params[:search] and params[:search]['state'] %>
    <input type="hidden" name="search[state]" value="<%= params[:search]['state'] %>">
  <% end %>

  <p>
    <%= link_to(t('.all_articles'), { action: 'index' }, { class: 'badge text-bg-secondary' }) %>
    <%= link_to(t('.published'), { action: 'index', search: { state: 'published' } }, { class: 'badge text-bg-success' }) %>
    <%= link_to(t('.withdrawn'), { action: 'index', search: { state: 'withdrawn' } }, { class: 'badge text-bg-danger' }) %>
    <%= link_to(t('.drafts'), { action: 'index', search: { state: 'drafts' } }, { class: 'badge text-bg-info' }) %>
    <%= link_to(t('.publication_pending'), { action: 'index', search: { state: 'pending' } }, { class: 'badge text-bg-warning' }) %>
  </p>

  <div class="card mb-4">
    <div class="card-header">
      <div class="d-sm-flex">
        <%= select_tag('search[user_id]', options_from_collection_for_select(User.all, 'id', 'name'), prompt: t('.select_an_author'), class: 'form-select ms-sm-auto me-sm-2') %>
        <%= select_tag('search[published_at]', options_for_select(Article.publication_months), prompt: t('.publication_date'), class: 'form-select me-sm-2') %>
        <input id="search" type="text" name="search[searchstring]" class="form-control me-sm-2" autocomplete="off">
        <%= submit_tag(t('.search'), class: 'btn btn-success') %>
        <span id="spinner" class="d-none"><%= image_tag('spinner.gif') %></span>
      </div>
    </div>
  </div>
  <table class="table table-hover">
    <thead>
      <tr>
        <th><%= t(".title") %></th>
        <th><%= t(".author") %></th>
        <th><%= t(".created_at") %></th>
        <th><%= t(".published_at") %></th>
        <th><%= t(".feedback") %></th>
        <th><%= t(".text_filter") %></th>
        <th><%= t(".actions") %></th>
      </tr>
    </thead>
    <tbody id="articleList">
      <%= render 'article_list', articles: @articles %>
    </tbody>
  </table>
<% end %>
